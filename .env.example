# Required
ANTHROPIC_API_KEY=your_api_key_here

# Optional — model selection
GBSE_MODEL=claude-sonnet-4-20250514

# Optional — pipeline behaviour
GBSE_MAX_ITERATIONS=3          # 1–10; default 3; values above 10 are clamped to 10
GBSE_LOG_LEVEL=normal          # silent | normal | verbose
GBSE_TIMEOUT_MS=120000         # wall-clock timeout per run in ms; 0 = disabled; default 120000

# Optional — per-role token budgets
# Reconstructor needs the largest budget: it receives full solver + auditor output
# and must produce a complete verified answer plus correction log.
GBSE_MAX_TOKENS_SOLVER=1024
GBSE_MAX_TOKENS_AUDITOR=2048
GBSE_MAX_TOKENS_RECONSTRUCTOR=4096
